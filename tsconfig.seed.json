{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "es2017",
    "lib": ["es2017"],
    "strict": false,
    "resolveJsonModule": true,
    "outDir": "./dist-seed",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["prisma/seed.ts", "src/**/*.ts"],
  "exclude": ["node_modules"]
}
