generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  deletedAt        DateTime?
  categoryOrder      String    @default("[]")
  hiddenCategories   String    @default("[]")

  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?

  accounts               Account[]
  categories             Category[]
  categoryRules          CategoryRule[]
  monthSummaries         MonthSummary[]
  monthCatTotals         MonthCategoryTotal[]
  uploads                Upload[]
  stagingUploads         StagingUpload[]
  stagingTxs             StagingTransaction[]
  insightCards           InsightCard[]
  subscriptionCandidates SubscriptionCandidate[]
  budgetTargets          BudgetTarget[]

  @@map("users")
}

model Account {
  id          String    @id @default(cuid())
  userId      String
  name        String
  institution String    @default("")
  accountType String    @default("checking")
  currency    String    @default("USD")
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?

  user         User          @relation(fields: [userId], references: [id])
  uploads      Upload[]
  transactions Transaction[]
  rawTxs       TransactionRaw[]

  @@map("accounts")
}

// ─── Upload ──────────────────────────────────────────────────────────────────
// reconciliationStatus values: PENDING | PASS | PASS_WITH_WARNINGS | FAIL | UNVERIFIABLE

model Upload {
  id               String   @id @default(cuid())
  userId           String
  accountId        String
  filename         String
  fileHash         String
  formatDetected   String   @default("")
  rowCountRaw      Int      @default(0)
  rowCountParsed   Int      @default(0)
  rowCountAccepted Int      @default(0)
  rowCountRejected Int      @default(0)
  dateRangeStart   DateTime?
  dateRangeEnd     DateTime?
  status           String   @default("processing")
  warnings         String   @default("[]")
  createdAt        DateTime @default(now())

  // ── Milestone 1: ingestion pipeline fields ─────────────────────────────────
  // reconciliationStatus: PENDING | PASS | PASS_WITH_WARNINGS | FAIL | UNVERIFIABLE
  reconciliationStatus   String    @default("PENDING")
  // reconciliationReport: JSON string — ReconciliationReport struct
  reconciliationReport   String?
  // parserVersion stored for determinism: same file + same parserVersion = identical output
  parserVersion          String    @default("1.0.0")
  // parserConfig: JSON string — CsvParserConfig | XlsxParserConfig | PdfParserConfig
  parserConfig           String?
  // version: incremented each time the same file (same SHA-256) is reprocessed
  version                Int       @default(1)
  // superseded: true when a newer reprocessed upload has replaced this one
  superseded             Boolean   @default(false)
  // reprocessedFromId: id of the previous Upload this was reprocessed from (null for original uploads)
  reprocessedFromId      String?
  // Statement-level totals extracted from bank export (stored as decimal strings, e.g. "1234.56")
  statementOpenBalance   String?
  statementCloseBalance  String?
  statementTotalCredits  String?
  statementTotalDebits   String?
  // Row counts broken out by ingestion result
  totalRowsUnresolved    Int       @default(0)
  // Timestamp when pipeline finished (null = still processing)
  completedAt            DateTime?
  // importReport: JSON string — ImportReport struct (generated after pipeline completes)
  importReport           String?

  // ── Date order selection (added in v2) ─────────────────────────────────────
  // dateOrderUsed: MDY | DMY | YMD | null (null = awaiting user confirmation)
  dateOrderUsed           String?
  // dateOrderSource: bank_default | auto_scored | user_confirmed
  dateOrderSource         String?
  // dateOrderConfidence: 0-100 (100 = certain, 0 = unknown)
  dateOrderConfidence     Int?
  // authoritativeDateColumn: posting | effective
  authoritativeDateColumn String?

  user            User             @relation(fields: [userId], references: [id])
  account         Account          @relation(fields: [accountId], references: [id])
  rawTxs          TransactionRaw[]
  transactions    Transaction[]
  auditLogEntries AuditLogEntry[]
  ingestionIssues IngestionIssue[]
  stagingUpload   StagingUpload?

  @@map("uploads")
}

// ─── TransactionRaw ───────────────────────────────────────────────────────────

model TransactionRaw {
  id             String   @id @default(cuid())
  uploadId       String
  accountId      String
  rawDate        String
  rawDescription String
  rawAmount      String
  rawCredit      String   @default("")
  rawDebit       String   @default("")
  rawBalance     String   @default("")
  sourceRowHash  String
  createdAt      DateTime @default(now())

  // ── Milestone 1: lineage + parse fields ────────────────────────────────────
  // sourceLocator: JSON string — CsvXlsxSourceLocator | PdfSourceLocator
  // e.g. {"type":"CSV","sheetName":null,"rowIndex":5,"dataRowIndex":3}
  sourceLocator  String   @default("{}")
  // rawLine: the literal text of this row as it appeared in the source file
  rawLine        String?
  // parseOrder: 0-based position in the file; never reordered (preserves source order)
  parseOrder     Int      @default(0)
  // rawFields: JSON string — all raw column values as { headerName: rawStringValue }
  rawFields      String   @default("{}")

  upload      Upload      @relation(fields: [uploadId], references: [id])
  account     Account     @relation(fields: [accountId], references: [id])
  transaction Transaction?

  @@unique([sourceRowHash])
  @@map("transactions_raw")
}

// ─── Transaction ─────────────────────────────────────────────────────────────
// ingestionStatus values: VALID | WARNING | UNRESOLVED | REJECTED
// dateAmbiguity values:   RESOLVED | AMBIGUOUS_MMDD_DDMM | UNPARSEABLE

model Transaction {
  id                     String    @id @default(cuid())
  rawId                  String    @unique
  accountId              String
  uploadId               String
  date                   DateTime
  description            String
  merchantNormalized     String    @default("")
  amount                 Float
  categoryId             String?
  userOverrideCategoryId String?
  categorizationSource   String    @default("rule")
  confidenceScore        Float     @default(0)
  isTransfer             Boolean   @default(false)
  isDuplicate            Boolean   @default(false)
  isExcluded             Boolean   @default(false)
  isForeignCurrency      Boolean   @default(false)
  foreignAmount          String?
  foreignCurrency        String?
  reviewedByUser         Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // ── Milestone 1: ingestion lineage fields ──────────────────────────────────

  // Dates — both nullable; if only one date column exists, it goes in postedDate
  postedDate             DateTime?
  transactionDate        DateTime?
  // Original date string from source before any parsing
  dateRaw                String?
  // dateAmbiguity: RESOLVED | AMBIGUOUS_MMDD_DDMM | UNPARSEABLE
  dateAmbiguity          String    @default("RESOLVED")
  // When ambiguous, both interpretations are stored for user resolution
  dateInterpretationA    DateTime? // MM/DD reading
  dateInterpretationB    DateTime? // DD/MM reading

  // Amount lineage
  amountRaw              String?   // original string e.g. "(12.34)" or "12.34-"
  currencyCode           String    @default("USD")
  currencyDetected       Boolean   @default(false)

  // Description lineage
  descriptionRaw         String    @default("") // raw before any normalization
  descriptionNormalized  String?                // after trim/collapse; null = same as raw
  // transformations: JSON string — ordered array of TransformationStep objects
  // e.g. [{"field":"amount","rule":"PARSE_PARENTHETICAL_NEGATIVE","before":"(12.34)","after":"-12.34","timestamp":"..."}]
  transformations        String    @default("[]")

  // Running balance (stored as decimal string for precision, e.g. "2587.53")
  runningBalance         String?
  runningBalanceRaw      String?

  // Additional metadata
  checkNumber            String?
  // Bank-provided unique transaction ID (strongest dedup key when present)
  bankTransactionId      String?
  pendingFlag            Boolean   @default(false)

  // Deduplication
  // bankFingerprint: deterministic SHA-256 of (postedDate|amount|descriptionRaw|runningBalance)
  bankFingerprint        String    @default("")
  // duplicateGroupId links rows that are possible duplicates of each other
  duplicateGroupId       String?
  isPossibleDuplicate    Boolean   @default(false)

  // Ingestion status — ingestionStatus: VALID | WARNING | UNRESOLVED | REJECTED
  ingestionStatus        String    @default("VALID")

  // Bank-provided category (from CSV "Transaction Category" column)
  bankCategoryRaw        String?   // exact string from CSV, e.g. "Gasoline/Fuel"
  bankCategoryNormalized String?   // trimmed + lowercased, e.g. "gasoline/fuel"
  appCategory            String?   // user's manual free-text category, always NULL on import
  // canonicalRowHash: SHA-256(rawDate|rawDesc|rawAmount|bankCategoryRaw|rowIndex)
  canonicalRowHash       String?

  // ── Manual-first categorization fields ────────────────────────────────────
  // needsReview: true when an "ask" mode rule matched — user must confirm
  needsReview            Boolean   @default(false)
  // assignedBy: 'manual' = user, 'rule' = auto-applied, null = not yet assigned
  assignedBy             String?
  // appliedRuleId: which CategoryRule auto-assigned this (null if manual / unassigned)
  appliedRuleId          String?

  // Balance chain validation (populated during Stage 4 reconciliation)
  balanceChainValid      Boolean?  // null = not yet checked
  // Stored as decimal strings for exact comparison
  balanceChainExpected   String?   // what running balance should be
  balanceChainActual     String?   // what it actually is in the source

  raw             TransactionRaw  @relation(fields: [rawId], references: [id])
  account         Account         @relation(fields: [accountId], references: [id])
  upload          Upload          @relation(fields: [uploadId], references: [id])
  category        Category?       @relation("CurrentCategory", fields: [categoryId], references: [id])
  overrideCategory Category?      @relation("OverrideCategory", fields: [userOverrideCategoryId], references: [id])
  appliedRule     CategoryRule?   @relation("AppliedRule", fields: [appliedRuleId], references: [id])
  historyEntries  CategoryHistory[]
  linksAsA        TransactionLink[] @relation("LinkA")
  linksAsB        TransactionLink[] @relation("LinkB")
  ingestionIssues IngestionIssue[]
  stagingTx       StagingTransaction?

  @@index([accountId, date])
  @@index([accountId, appCategory])
  @@index([bankFingerprint])
  @@index([uploadId, ingestionStatus])
  @@map("transactions")
}

model TransactionLink {
  id              String   @id @default(cuid())
  transactionAId  String
  transactionBId  String
  linkType        String
  confidence      Float    @default(0)
  confirmedByUser Boolean  @default(false)

  transactionA Transaction @relation("LinkA", fields: [transactionAId], references: [id])
  transactionB Transaction @relation("LinkB", fields: [transactionBId], references: [id])

  @@map("transaction_links")
}

// ─── AuditLogEntry ────────────────────────────────────────────────────────────
// Append-only log of every pipeline action (PARSE, NORMALIZE, DEDUP, RECONCILE).
// stage values: PARSE | NORMALIZE | DEDUP | RECONCILE
// level values: INFO | WARN | ERROR

model AuditLogEntry {
  id        String   @id @default(cuid())
  uploadId  String
  timestamp DateTime @default(now())
  // stage: PARSE | NORMALIZE | DEDUP | RECONCILE
  stage     String
  // level: INFO | WARN | ERROR
  level     String
  message   String
  // context: JSON string — { rowIndex?, field?, before?, after?, rule? }
  context   String?

  upload Upload @relation(fields: [uploadId], references: [id])

  @@index([uploadId])
  @@map("audit_log_entries")
}

// ─── IngestionIssue ───────────────────────────────────────────────────────────
// One row per issue requiring attention or user action.
// issueType values: DATE_AMBIGUOUS | AMOUNT_PARSE_FAIL | BALANCE_CHAIN_BREAK |
//                   POSSIBLE_DUPLICATE | MERGED_CELL | HEADER_AMBIGUOUS |
//                   TRUNCATED_FILE | OCR_CONFIDENCE_LOW | COLUMN_COUNT_MISMATCH
// severity values:  ERROR | WARNING | INFO

model IngestionIssue {
  id              String    @id @default(cuid())
  uploadId        String
  transactionId   String?
  // issueType: DATE_AMBIGUOUS | AMOUNT_PARSE_FAIL | BALANCE_CHAIN_BREAK | POSSIBLE_DUPLICATE | ...
  issueType       String
  // severity: ERROR | WARNING | INFO
  severity        String
  description     String
  suggestedAction String?
  resolved        Boolean   @default(false)
  // resolvedBy: USER | AUTO
  resolvedBy      String?
  resolvedAt      DateTime?
  // resolution: JSON string — what the user chose or what AUTO did
  resolution      String?

  upload      Upload       @relation(fields: [uploadId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@index([uploadId, resolved])
  @@map("ingestion_issues")
}

model Category {
  id         String    @id @default(cuid())
  userId     String?
  name       String
  parentId   String?
  color      String    @default("#6366f1")
  icon       String    @default("💳")
  isIncome   Boolean   @default(false)
  isTransfer Boolean   @default(false)
  isSystem   Boolean   @default(true)
  sortOrder  Int       @default(0)

  user              User?            @relation(fields: [userId], references: [id])
  rules             CategoryRule[]
  transactions      Transaction[]    @relation("CurrentCategory")
  overrideTxs       Transaction[]    @relation("OverrideCategory")
  historyOld        CategoryHistory[] @relation("OldCategory")
  historyNew        CategoryHistory[] @relation("NewCategory")
  monthTotals       MonthCategoryTotal[]
  stagingTxs        StagingTransaction[]
  budgetTargets     BudgetTarget[]

  @@map("categories")
}

model CategoryRule {
  id         String   @id @default(cuid())
  userId     String?
  categoryId String
  matchType  String
  matchValue String
  priority   Int      @default(0)
  isSystem   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  // ── Manual-first rules fields ──────────────────────────────────────────────
  // mode: 'always' = auto-apply on import; 'ask' = route to Needs Review
  mode           String  @default("always")
  // confidence: only 'high' rules are auto-applied
  confidence     String  @default("high")
  // isEnabled: user can disable without deleting
  isEnabled      Boolean @default(true)
  // scopeAccountId: null = global, non-null = account-scoped rule
  scopeAccountId String?

  // ── Structured matching fields (staging / learning rules) ─────────────────
  // name: user-visible label, auto-generated if null
  name             String?
  // vendorKey: normalized vendor string (lowercase, stripped bank prefixes)
  vendorKey        String  @default("")
  // amountExact: integer cents for exact-amount matching
  amountExact      Int?
  // amountMin/amountMax: for range matching (inclusive, integer cents)
  amountMin        Int?
  amountMax        Int?
  // containsText: substring to match in description (lowercased)
  containsText     String?
  // appliesTo: which transaction direction this rule applies to
  appliesTo        String  @default("both")  // debits | credits | both
  // hit tracking
  hitCount         Int       @default(0)
  lastHitAt        DateTime?
  // audit: which staging transaction IDs triggered rule creation
  createdFromTxIds String    @default("[]")  // JSON array

  user            User?               @relation(fields: [userId], references: [id])
  category        Category            @relation(fields: [categoryId], references: [id])
  appliedTxs      Transaction[]       @relation("AppliedRule")
  stagingTxs      StagingTransaction[] @relation("StagingAppliedRule")
  ruleHits        RuleHit[]

  @@map("category_rules")
}

// ─── Staging ──────────────────────────────────────────────────────────────────
// Transactions live here after upload, before user commits them to the ledger.

model StagingUpload {
  id          String   @id @default(cuid())
  userId      String
  uploadId    String   @unique  // parent Upload record
  // status: ready | committed | discarded
  status      String   @default("ready")
  rowCount    Int      @default(0)
  autoCount   Int      @default(0)  // auto-categorized by rules
  reviewCount Int      @default(0)  // flagged needs_review
  newVendors  Int      @default(0)  // first-time vendors
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id])
  upload       Upload             @relation(fields: [uploadId], references: [id])
  transactions StagingTransaction[]

  @@index([userId, status])
  @@map("staging_uploads")
}

model StagingTransaction {
  id              String    @id @default(cuid())
  stagingUploadId String
  userId          String
  // Source upload id for convenience queries
  uploadId        String

  // Normalized fields from the ingestion pipeline
  date            DateTime?
  vendorRaw       String    @default("")
  vendorKey       String    @default("")   // normalized vendor
  amountCents     Int       @default(0)   // signed integer cents
  description     String    @default("")
  bankCategoryRaw String?

  // Categorization
  categoryId      String?
  // categorySource: none | manual | rule | bank
  categorySource  String    @default("none")
  ruleId          String?
  ruleReason      String?   // e.g. "Vendor + Exact Amount"

  // status: uncategorized | categorized | needs_review | excluded | transfer
  status          String    @default("uncategorized")

  // Persisted suggestions — computed at import time, avoids re-scrubbing on every view
  // Priority: transfer detection → bank category → engine keyword match
  suggestionCategory   String?          // e.g. "Food & Dining"
  suggestionConfidence String?          // 'high' | 'medium' | 'low'
  suggestionSource     String?          // 'bank' | 'engine'
  // Recurring flag — true when this vendor appears 2+ times in the upload with ±10% amounts
  isRecurring          Boolean   @default(false)

  // Set when committed to ledger
  committedAt     DateTime?
  transactionId   String?   @unique  // FK to Transaction after commit

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stagingUpload   StagingUpload  @relation(fields: [stagingUploadId], references: [id])
  user            User           @relation(fields: [userId], references: [id])
  category        Category?      @relation(fields: [categoryId], references: [id])
  appliedRule     CategoryRule?  @relation("StagingAppliedRule", fields: [ruleId], references: [id])
  transaction     Transaction?   @relation(fields: [transactionId], references: [id])
  ruleHits        RuleHit[]

  @@index([stagingUploadId, status])
  @@index([userId, status])
  @@index([vendorKey])
  @@map("staging_transactions")
}

model RuleHit {
  id              String   @id @default(cuid())
  ruleId          String
  stagingTxId     String
  uploadId        String
  // null = pending commit, true = committed with this category, false = overridden
  wasAccepted     Boolean?
  finalCategoryId String?
  createdAt       DateTime @default(now())

  rule      CategoryRule       @relation(fields: [ruleId], references: [id])
  stagingTx StagingTransaction @relation(fields: [stagingTxId], references: [id])

  @@index([ruleId])
  @@index([stagingTxId])
  @@map("rule_hits")
}

model CategoryHistory {
  id            String   @id @default(cuid())
  transactionId String
  oldCategoryId String?
  newCategoryId String
  changedBy     String
  changedAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])
  oldCategory Category?   @relation("OldCategory", fields: [oldCategoryId], references: [id])
  newCategory Category    @relation("NewCategory", fields: [newCategoryId], references: [id])

  @@map("category_history")
}

model MonthSummary {
  id               String   @id @default(cuid())
  userId           String
  year             Int
  month            Int
  totalIncome      Float    @default(0)
  totalSpending    Float    @default(0)
  net              Float    @default(0)
  transactionCount Int      @default(0)
  isPartialMonth   Boolean  @default(false)
  dateRangeStart   DateTime?
  dateRangeEnd     DateTime?
  computedAt       DateTime @default(now())
  isStale          Boolean  @default(false)

  user       User                 @relation(fields: [userId], references: [id])
  catTotals  MonthCategoryTotal[]

  @@unique([userId, year, month])
  @@map("month_summaries")
}

model MonthCategoryTotal {
  id             String @id @default(cuid())
  userId         String
  year           Int
  month          Int
  categoryId     String
  total          Float  @default(0)
  transactionCount Int  @default(0)
  pctOfSpending  Float  @default(0)
  summaryId      String?

  user     User         @relation(fields: [userId], references: [id])
  category Category     @relation(fields: [categoryId], references: [id])
  summary  MonthSummary? @relation(fields: [summaryId], references: [id])

  @@unique([userId, year, month, categoryId])
  @@map("month_category_totals")
}

model AnomalyAlert {
  id            String   @id @default(cuid())
  userId        String
  year          Int
  month         Int
  alertType     String
  categoryId    String?
  message       String
  amount        Float?
  threshold     Float?
  isDismissed   Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@map("anomaly_alerts")
}

// ─── InsightCard ──────────────────────────────────────────────────────────────
// One row per insight type per (user, year, month). Regenerated on each compute
// pass; isDismissed is sticky and survives regeneration via upsert.

model InsightCard {
  id             String   @id @default(cuid())
  userId         String
  year           Int
  month          Int
  cardType       String
  priority       Int
  title          String
  summary        String
  supportingData Json
  actions        Json
  confidence     String
  iconSuggestion String
  isDismissed    Boolean  @default(false)
  generatedAt    DateTime @default(now())
  numbersUsed    Json     @default("[]")
  filters        Json?
  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, year, month, cardType])
  @@index([userId, year, month, isDismissed])
  @@map("insight_cards")
}

// ─── SubscriptionCandidate ────────────────────────────────────────────────────
// A merchant that appears to be a recurring charge. Written by the subscription
// detection pass and referenced by the subscription insight cards.

model SubscriptionCandidate {
  id                     String    @id @default(cuid())
  userId                 String
  merchantNormalized     String
  estimatedMonthlyAmount Float
  recurringConfidence    String
  subscriptionScore      Int
  consecutiveMonths      Int
  serviceCategory        String?
  estimatedNextCharge    DateTime?
  isConfirmedByUser      Boolean   @default(false)
  isSuppressed           Boolean   @default(false)
  firstSeenAt            DateTime  @default(now())
  lastSeenAt             DateTime  @default(now())
  user                   User      @relation(fields: [userId], references: [id])

  @@unique([userId, merchantNormalized])
  @@map("subscription_candidates")
}

// ─── BudgetTarget ─────────────────────────────────────────────────────────────
// Monthly spending target per category. null amountCents = no budget set.
// Period "monthly" is the only supported period for now.

model BudgetTarget {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  amountCents Int     // monthly target in integer cents (e.g. 50000 = $500.00)
  period     String   @default("monthly")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, period])
  @@map("budget_targets")
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   // e.g. "login:1.2.3.4" or "upload:1.2.3.4"
  count     Int      @default(1)
  windowEnd DateTime // when the current window expires

  @@unique([key])
  @@index([windowEnd])
  @@map("rate_limits")
}
