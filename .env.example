# PostgreSQL connection string (Neon, Supabase, etc.)
# Pooled connection — used by Prisma at runtime
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"

# Direct (non-pooled) connection — used by Prisma for migrations
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret for signing JWTs — min 32 chars, random string
JWT_SECRET="change-me-to-a-long-random-secret-min-32-chars"

# OpenAI API key — used for AI-assisted transaction categorisation and Q&A
OPENAI_API_KEY="sk-..."

# Tavily Search API key — enables web search in Q&A (price comparisons, alternatives)
# Free tier: 1,000 searches/month — get key at https://tavily.com
# Optional: if not set, Q&A works without web search
TAVILY_API_KEY=""

# App name displayed in the UI
NEXT_PUBLIC_APP_NAME="BudgetLens"
